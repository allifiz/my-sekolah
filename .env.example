# Pooled PostgreSQL connection used by the application at runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/my_sekolah?schema=public"

# Direct PostgreSQL connection used by Prisma migrations.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/my_sekolah?schema=public"

# Initial platform owner created by `npm run db:seed`.
SEED_PLATFORM_OWNER_EMAIL="owner@example.com"
SEED_PLATFORM_OWNER_NAME="Platform Owner"
