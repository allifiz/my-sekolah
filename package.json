{
  "name": "my-sekolah",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "tsx --test tests/policies.test.ts",
    "test:integration": "tsx --test tests/integration.test.ts",
    "test:e2e": "tsx tests/e2e-smoke.ts",
    "test:all": "npm test && npm run test:integration",
    "vercel-build": "prisma migrate deploy && tsx prisma/seed.ts && tsx prisma/set-owner-password.ts && npm test && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:format": "prisma format",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:set-owner-password": "tsx prisma/set-owner-password.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.2",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.9.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.16.2",
    "tailwindcss": "4.3.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.0"
  },
  "packageManager": "npm@11.0.0",
  "engines": {
    "node": "22.x"
  }
}
